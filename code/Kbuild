# Kbuild for TearGame Kernel Module
# Target: ARM64 (aarch64), Linux Kernel 5.10+

# 模块名必须和 kadeflow.yaml 里的 module_name 完全一致
obj-m := file_copy.o

# 源文件列表
file_copy-objs := \
	src/main.o \
	src/command.o \
	src/memory.o \
	src/memory_safe.o \
	src/memory_batch.o \
	src/process.o \
	src/process_cache.o \
	src/touch.o \
	src/hook.o \
	src/stealth.o \
	src/auth.o \
	src/antidbg.o \
	src/file_hide.o \
	src/proc_hide.o \
	src/proc_hide_path.o \
	src/so_hide.o \
	src/shadow_hook.o \
	src/syscall_block.o

# 编译选项
ccflags-y := -I$(src)/src           # 让编译器能找到和 .c 放在一起的 .h
ccflags-y += -DMODULE_NAME=\"file_copy\"
ccflags-y += -O2 -fno-strict-aliasing
ccflags-y += -fno-common -fno-delete-null-pointer-checks

# 调试选项（需要时取消注释）
# ccflags-y += -DDEBUG -g